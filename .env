# CAUTION
#
# 1. Before changing the variables "*_NAME" for example "DB_MIG_NAME", also change
#    the name of the files in "setup/gitea/initial_repos/*.tar.xz" for example
#    setup/gitea/initial_repos/t51back.tar.xz and DB_MIG_NAME=t51back must match.




# VERSIONING AND ENVIRONMENT
ENV=local                     # local | test | PROD
BRANCH=main                   # CAUTION: Keep sync with JenkinsScript-start.sh file
VERSION=0.0.1

#Random Secret, used in webhooks token.
SHARED_TOKEN=my-secret


# Domain and  SSL                 Local                test                  PROD
MY_DOMAIN=mariomv-local.org    # mariomv-local.org    mariomv-test.org      mariomv.duckdns.org
MY_EMAIL=somsos112@gmail.com
MY_USER=mario1
MY_PASS=mario1p


# Database
DB_SERVER=t51db
DB_SCHEMA=t51DB_schema
DB_USER=t51DB_user
DB_PASS=t51DB_pass
DB_VOLUME=t51DB_vol1 # It's also hardcoded in docker-compose.yml, in 'volumes:' section
DB_IP=172.30.0.101
DB_PORT=5001
DB_IMAGE=postgres:17.6-alpine3.22

# Database Migrations
DB_MIG_NAME=t51mig-db
DB_MIG_REPO=ssh://git@gitea:22/${MY_USER}/${DB_MIG_NAME}.git
DB_MIG_IMAGE=liquibase:4.33-alpine
DB_UTILS_IMAGE=alpine/psql:17.6


# Back-end
BACK_NAME=t51back
BACK_REPO=ssh://git@gitea:22/${MY_USER}/${BACK_NAME}.git
BACK_IMAGE=${BACK_NAME}:0.0.1
BACK_IP=172.30.0.102
BACK_URL=http://api.${MY_DOMAIN}


# Front-end
FRONT_NAME=t51front
FRONT_REPO=ssh://git@gitea:22/${MY_USER}/${FRONT_NAME}.git
FRONT_IMAGE=${FRONT_NAME}:0.0.1
FRONT_IP=172.30.0.103
FRONT_PORT=80


# Dev-Ops
DEVOPS_NAME=t51devops
DEVOPS_REPO=ssh://git@gitea:22/${MY_USER}/${DEVOPS_NAME}.git
DEVOPS_WORKDIR=/var/jenkins_home/workspace


GITEA_IP=172.30.0.201
GITEA_PORT=3000

JENKINS_IP=172.30.0.202
JENKINS_PORT=3001

REVERSE_PROXY_IP=172.30.0.203
ACME_COMPANION_IP=172.30.0.204


# just to hide warnings when is built from terminal
BUILD_NUMBER=997

