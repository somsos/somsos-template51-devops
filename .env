MY_EMAIL=somsos112@gmail.com
MY_USER=mario1
MY_PASS=mario1p


# Database
DB_SERVER=t51db
DB_SCHEMA=t51DB_schema
DB_USER=t51DB_user
DB_PASS=t51DB_pass
